<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
			fx:controller="controllers.gestionutilisateurs.SignedInShellController"
			styleClass="immersive-root">
	<left>
		<VBox prefWidth="278.0" minWidth="260.0" spacing="10.0" styleClass="sidebar-immersive">
			<padding>
				<Insets top="22.0" right="16.0" bottom="18.0" left="16.0"/>
			</padding>
			<children>
				<VBox spacing="4.0">
					<children>
						<Label text="SMART VOYAGE  🌍" styleClass="sidebar-logo"/>
						<Label text="Signed-in mode" styleClass="sidebar-subtitle"/>
					</children>
				</VBox>

				<Separator styleClass="sidebar-rule"/>

				<Button text="Home" onAction="#onHome">
					<styleClass>
						<String fx:value="sidebar-nav-item"/>
						<String fx:value="sidebar-nav-item-active"/>
					</styleClass>
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-home"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Offers" onAction="#onOffres" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-offers"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Agencies" onAction="#onAgences" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-agencies"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-messages"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-recommend"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Events" onAction="#onEvenement" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-events"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Region VBox.vgrow="ALWAYS"/>

				<Separator styleClass="sidebar-rule"/>

				<Button text="Premium" onAction="#onPremium" styleClass="premium-nav-button">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-premium"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-notifications"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="My Profile" onAction="#onProfile" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-profile"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Button text="Dashboard IA" fx:id="dashboardIaButton" onAction="#onDashboardIa" styleClass="sidebar-nav-item">
					<graphic>
						<Region>
							<styleClass>
								<String fx:value="sidebar-nav-icon"/>
								<String fx:value="icon-dashboard"/>
							</styleClass>
						</Region>
					</graphic>
				</Button>

				<Separator styleClass="sidebar-rule"/>

				<HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-footer-block">
					<children>
						<Button onAction="#onThemeToggle" styleClass="theme-immersive-button" accessibleText="Toggle theme">
							<graphic>
								<Region>
									<styleClass>
										<String fx:value="sidebar-nav-icon"/>
										<String fx:value="icon-theme"/>
									</styleClass>
								</Region>
							</graphic>
						</Button>
						<Region HBox.hgrow="ALWAYS"/>
						<Button text="Logout" onAction="#onLogout" styleClass="sidebar-nav-item">
							<graphic>
								<Region>
									<styleClass>
										<String fx:value="sidebar-nav-icon"/>
										<String fx:value="icon-logout"/>
									</styleClass>
								</Region>
							</graphic>
						</Button>
					</children>
				</HBox>
			</children>
		</VBox>
	</left>

	<center>
		<StackPane styleClass="offers-immersive-stack">
			<children>
				<Region styleClass="offers-page-overlay"/>
				<Region styleClass="offers-cards-spotlight"/>
				<VBox alignment="CENTER" spacing="10.0">
					<children>
						<Label fx:id="userGreetingLabel" text="Welcome back" styleClass="offers-title"/>
						<Label fx:id="roleLabel" text="User session active" styleClass="offers-subtitle"/>
					</children>
				</VBox>
			</children>
		</StackPane>
	</center>
</BorderPane>
