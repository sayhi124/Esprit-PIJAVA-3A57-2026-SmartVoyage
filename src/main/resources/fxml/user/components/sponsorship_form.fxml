<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.gestionevenements.SponsorshipFormController"
            spacing="12"
            prefWidth="640"
            maxWidth="640"
      styleClass="sponsor-form-root">
    <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>

    <Label text="Sponsor this event" styleClass="sponsor-form-title"/>

    <VBox spacing="4">
        <Label text="Full name" styleClass="sponsor-form-label"/>
        <TextField fx:id="fullNameField" promptText="Your full name" styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Email" styleClass="sponsor-form-label"/>
        <TextField fx:id="emailField" promptText="you@example.com" styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Phone (optional)" styleClass="sponsor-form-label"/>
        <TextField fx:id="phoneField" promptText="+216 ..." styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Contribution amount" styleClass="sponsor-form-label"/>
        <TextField fx:id="amountField" promptText="100.000" styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Message (optional)" styleClass="sponsor-form-label"/>
        <TextArea fx:id="messageArea" promptText="Why do you want to sponsor this event?" wrapText="true" prefRowCount="4"
                  styleClass="sponsor-form-input sponsor-form-textarea"/>
    </VBox>
</VBox>
