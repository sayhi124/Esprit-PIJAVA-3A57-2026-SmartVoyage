<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.gestionevenements.ParticipationJoinFormController"
      spacing="12"
      prefWidth="640"
      maxWidth="640"
      styleClass="sponsor-form-root">
    <padding>
        <Insets top="8" right="8" bottom="8" left="8"/>
    </padding>

    <Label text="Join this event" styleClass="sponsor-form-title"/>

    <VBox spacing="4">
        <Label text="Full name" styleClass="sponsor-form-label"/>
        <TextField fx:id="fullNameField" promptText="Your full name" styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Phone (optional)" styleClass="sponsor-form-label"/>
        <TextField fx:id="phoneField" promptText="+216 ..." styleClass="sponsor-form-input"/>
    </VBox>

    <VBox spacing="4">
        <Label text="Why do you want to join?" styleClass="sponsor-form-label"/>
        <TextArea fx:id="noteArea" promptText="Write a short participation request..." wrapText="true" prefRowCount="4"
                  styleClass="sponsor-form-input sponsor-form-textarea"/>
    </VBox>

    <CheckBox fx:id="rulesCheck" text="I accept participation rules for this event." styleClass="sponsor-form-label"/>
</VBox>
