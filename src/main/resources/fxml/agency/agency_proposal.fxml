<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionagences.AgencyProposalController"
            styleClass="immersive-root">
    <left>
        <VBox prefWidth="278.0" minWidth="260.0" spacing="10.0" styleClass="sidebar-immersive">
            <padding><Insets top="22.0" right="16.0" bottom="18.0" left="16.0"/></padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="✦ SmartVoyage" styleClass="sidebar-logo"/>
                        <Label text="My agency" styleClass="sidebar-subtitle"/>
                    </children>
                </VBox>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⌂  Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                <Button text="🧳  Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                <Button text="📍  Agencies" onAction="#onAgences">
                    <styleClass>
                        <String fx:value="sidebar-nav-item"/>
                        <String fx:value="sidebar-nav-item-active"/>
                    </styleClass>
                </Button>
                <Button text="✉  Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                <Button text="⭐  Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                <Button text="📅  Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                <Button text="📊  Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="👑  Premium" onAction="#onPremium" styleClass="premium-nav-button"/>
                <Button text="🔔  Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                <Button text="👤  My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⎋  Deconnexion" onAction="#onLogout" styleClass="sidebar-nav-item"/>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-footer-block">
                    <children>
                        <Button text="🌙" onAction="#onThemeToggle" styleClass="theme-immersive-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="offers-immersive-stack">
            <children>
                <Region styleClass="offers-page-overlay"/>
                <Region styleClass="offers-cards-spotlight"/>
                <BorderPane pickOnBounds="false" styleClass="hero-foreground-pane">
                    <padding><Insets top="20.0" right="34.0" bottom="28.0" left="34.0"/></padding>
                    <top>
                        <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="top-mini-bar">
                            <children>
                                <Label text="Agency Proposal" styleClass="offers-mini-logo"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Back to agencies" onAction="#onBackToAgencies" styleClass="agency-proposal-back-button" mnemonicParsing="false"/>
                            </children>
                        </HBox>
                    </top>
                    <center>
                        <StackPane alignment="TOP_CENTER" pickOnBounds="false" styleClass="agency-proposal-center-stack">
                            <children>
                                <VBox spacing="18.0" alignment="TOP_CENTER" maxWidth="720.0" fillWidth="true" styleClass="agency-proposal-panel">
                                    <padding><Insets top="22.0" right="28.0" bottom="30.0" left="28.0"/></padding>
                                    <children>
                                        <VBox fx:id="statusContainer" spacing="16.0" visible="false" managed="false" alignment="TOP_CENTER" maxWidth="Infinity" minWidth="560.0" prefWidth="664.0" fillWidth="true" styleClass="agency-proposal-status-panel">
                                            <children>
                                                <Label fx:id="statusGlyphLabel" text="" managed="false" visible="false" alignment="CENTER" maxWidth="Infinity" textAlignment="CENTER" styleClass="agency-proposal-status-glyph"/>
                                                <Label fx:id="statusTitleLabel" text="Status" wrapText="true" maxWidth="664.0" alignment="CENTER" textAlignment="CENTER" styleClass="offers-title agency-proposal-status-title"/>
                                                <Label fx:id="statusMessageLabel" text="Status message" wrapText="true" maxWidth="664.0" alignment="CENTER" textAlignment="CENTER" styleClass="offers-subtitle agency-proposal-status-message"/>
                                                <HBox spacing="12.0" alignment="CENTER">
                                                    <children>
                                                        <Button fx:id="statusActionButton" text="Action" visible="false" managed="false" styleClass="agency-proposal-primary-button" mnemonicParsing="false"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                        <VBox fx:id="formContainer" spacing="12.0" alignment="TOP_CENTER" maxWidth="664.0" fillWidth="true">
                                            <children>
                                                <Label text="Submit agency admin proposal" styleClass="offers-title" textAlignment="CENTER" wrapText="true"/>
                                                <Label text="Countries are loaded from API (flag on the left, choice on the right). Fill in the requested agency name."
                                                       wrapText="true" styleClass="offers-subtitle" textAlignment="CENTER"/>
                                                <Label text="Agency name" styleClass="agency-proposal-field-label"/>
                                                <TextField fx:id="agencyNameField" promptText="Agency name" maxWidth="664.0" styleClass="agency-proposal-text-field"/>
                                                <Label text="Country" styleClass="agency-proposal-field-label"/>
                                                <HBox alignment="CENTER_LEFT" spacing="14.0" maxWidth="664.0" styleClass="agency-proposal-country-row">
                                                    <children>
                                                        <StackPane fx:id="countryFlagFrame" minWidth="72.0" prefWidth="72.0" maxWidth="72.0" minHeight="48.0" prefHeight="48.0" maxHeight="48.0" styleClass="agency-proposal-flag-frame">
                                                            <children>
                                                                <ImageView fx:id="countryFlagImageView" fitWidth="68.0" fitHeight="44.0" preserveRatio="true" smooth="true" pickOnBounds="true"/>
                                                            </children>
                                                        </StackPane>
                                                        <ComboBox fx:id="countryCombo" maxWidth="Infinity" HBox.hgrow="ALWAYS" prefWidth="360.0" promptText="Select country" styleClass="agency-proposal-combo"/>
                                                    </children>
                                                </HBox>
                                                <Label text="Message to admin (optional)" styleClass="agency-proposal-field-label"/>
                                                <TextArea fx:id="messageToAdminField" promptText="Message to admin (optional)" prefRowCount="5" maxWidth="664.0" wrapText="true" styleClass="agency-proposal-text-area"/>
                                                <HBox spacing="12.0" alignment="CENTER_LEFT">
                                                    <children>
                                                        <Button text="Submit proposal" onAction="#onSubmitProposal" styleClass="agency-proposal-primary-button" mnemonicParsing="false"/>
                                                        <Label fx:id="feedbackLabel" text="" wrapText="true" styleClass="offers-subtitle"/>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </StackPane>
                    </center>
                </BorderPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
