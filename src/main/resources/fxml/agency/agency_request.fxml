<?xml version="1.0" encoding="UTF-8"?>

<!-- Demande d'agrément (integration agency/request). -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.gestionagences.AgencyRequestController"
           prefHeight="720.0"
           prefWidth="1200.0"
           styleClass="cosmic-root agency-app-root">
   <children>
      <Region maxHeight="Infinity" maxWidth="Infinity" mouseTransparent="true" styleClass="welcome-starfield" />
      <VBox alignment="TOP_CENTER" maxHeight="Infinity" maxWidth="Infinity" spacing="0.0">
         <children>
            <fx:include fx:id="loggedHeader" source="../components/app_logged_header.fxml" />
            <VBox alignment="CENTER" VBox.vgrow="ALWAYS">
               <padding>
                  <Insets bottom="40.0" left="24.0" right="24.0" top="24.0" />
               </padding>
               <children>
                  <VBox alignment="TOP_LEFT" maxWidth="520.0" spacing="14.0" styleClass="agency-request-card">
                     <padding>
                        <Insets bottom="32.0" left="28.0" right="28.0" top="28.0" />
                     </padding>
                     <children>
                        <Label styleClass="agency-request-title" text="Demande d'agrément agence" />
                        <Label styleClass="agency-request-sub" text="Indiquez le nom de votre agence et un message pour l'administrateur. Votre demande sera examinée avant activation." wrapText="true" />
                        <Label styleClass="agency-request-label" text="Nom de l'agence demandée" />
                        <TextField fx:id="agencyNameField" promptText="Nom de l'agence demandé" styleClass="agency-request-input" />
                        <Label styleClass="agency-request-label" text="Pays de l'agence" />
                        <ComboBox fx:id="countryCombo" prefWidth="440.0" promptText="Choisir un pays" styleClass="agency-request-input" />
                        <Label styleClass="agency-request-label" text="Message à l'administrateur" />
                        <TextArea fx:id="messageArea" prefRowCount="4" promptText="Message optionnel pour l'administrateur…" styleClass="agency-request-textarea" wrapText="true" />
                        <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#onSubmit" styleClass="form-btn form-btn-tall" text="Envoyer la demande" />
                        <Hyperlink onAction="#onBack" styleClass="form-link-btn auth-footer-link" text="← Retour aux agences" />
                        <Label fx:id="messageLabel" styleClass="message-label" wrapText="true" />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>
