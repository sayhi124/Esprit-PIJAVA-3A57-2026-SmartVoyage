<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import com.jfoenix.controls.JFXButton?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionagences.MyAgencyController"
            styleClass="immersive-root">
    <left>
        <VBox prefWidth="278.0" minWidth="260.0" spacing="10.0" styleClass="sidebar-immersive">
            <padding><Insets top="22.0" right="16.0" bottom="18.0" left="16.0"/></padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="✦ SmartVoyage" styleClass="sidebar-logo"/>
                        <Label text="Mon agence" styleClass="sidebar-subtitle"/>
                    </children>
                </VBox>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⌂  Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                <Button text="🧳  Offres" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                <Button text="📍  Agences" onAction="#onAgences">
                    <styleClass>
                        <String fx:value="sidebar-nav-item"/>
                        <String fx:value="sidebar-nav-item-active"/>
                    </styleClass>
                </Button>
                <Button text="✉  Messagerie" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                <Button text="⭐  Recommandation" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                <Button text="📅  Evenement" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                <Button text="📊  Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="👑  Premium" onAction="#onPremium" styleClass="premium-nav-button"/>
                <Button text="🔔  Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                <Button text="👤  Mon Profil" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⎋  Deconnexion" onAction="#onLogout" styleClass="sidebar-nav-item"/>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-footer-block">
                    <children>
                        <Button text="🌙" onAction="#onThemeToggle" styleClass="theme-immersive-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="offers-immersive-stack">
            <children>
                <Region styleClass="offers-page-overlay"/>
                <Region styleClass="offers-cards-spotlight"/>

                <StackPane styleClass="agency-page-root">
                    <padding><Insets top="20.0" right="24.0" bottom="22.0" left="24.0"/></padding>
                    <children>
                        <VBox spacing="20.0" styleClass="agency-page-content">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="agency-header-row">
                                    <children>
                                        <Label text="Agency Profile" styleClass="offers-mini-logo"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Back to agencies" onAction="#onBackToAgencies" styleClass="offers-top-login-button"/>
                                    </children>
                                </HBox>

                                <StackPane fx:id="bannerStack" prefHeight="236.0" minHeight="220.0" maxHeight="260.0">
                                    <children>
                                        <Region styleClass="agency-cover-banner"/>
                                        <ImageView fx:id="coverImageView" preserveRatio="false" pickOnBounds="true" smooth="true" cache="true"
                                                   styleClass="agency-cover-image"/>
                                        <Region styleClass="agency-cover-gradient"/>
                                        <Button fx:id="editCoverButton" text="✎ Edit cover" onAction="#onEditCover"
                                                visible="false" managed="false" styleClass="agency-overlay-action agency-cover-hover-action"
                                                StackPane.alignment="TOP_RIGHT">
                                            <StackPane.margin><Insets top="14.0" right="14.0"/></StackPane.margin>
                                        </Button>
                                    </children>
                                </StackPane>

                                <HBox spacing="24.0" styleClass="agency-lower-section" VBox.vgrow="ALWAYS">
                                    <children>
                                        <VBox prefWidth="300.0" minWidth="300.0" maxWidth="300.0" spacing="14.0">
                                            <children>
                                                <StackPane prefHeight="74.0">
                                                    <children>
                                                        <StackPane prefWidth="132.0" prefHeight="132.0" styleClass="agency-avatar-shell"
                                                                   StackPane.alignment="TOP_LEFT">
                                                            <StackPane.margin><Insets top="-58.0" left="12.0"/></StackPane.margin>
                                                            <children>
                                                                <ImageView fx:id="avatarImageView" fitWidth="120.0" fitHeight="120.0" preserveRatio="false"
                                                                           pickOnBounds="true" smooth="true" cache="true" styleClass="agency-avatar-image"/>
                                                                <Label fx:id="avatarFallbackLabel" text="🏢" styleClass="agency-avatar-icon"/>
                                                                <Button fx:id="editAvatarButton" text="✎" onAction="#onEditAvatar"
                                                                        visible="false" managed="false" styleClass="agency-avatar-edit agency-avatar-hover-action"
                                                                        StackPane.alignment="BOTTOM_RIGHT">
                                                                    <StackPane.margin><Insets right="3.0" bottom="3.0"/></StackPane.margin>
                                                                </Button>
                                                            </children>
                                                        </StackPane>
                                                    </children>
                                                </StackPane>

                                                <VBox prefWidth="300.0" minWidth="300.0" maxWidth="300.0" spacing="10.0" styleClass="agency-info-card">
                                                    <padding><Insets top="16.0" right="14.0" bottom="16.0" left="14.0"/></padding>
                                                    <children>
                                                        <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyTitleLabel" text="My Agency" styleClass="agency-name-title"/>
                                                                <Label fx:id="agencyVerifiedBadgeLabel" text="✔ Verified" visible="false" managed="false" styleClass="agency-verified-badge"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editNameFieldButton" text="✎" onAction="#onEditNameField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>

                                                        <HBox fx:id="descriptionRow" alignment="TOP_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyDescriptionLabel" text="Description" wrapText="true" styleClass="agency-info-text"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editDescriptionFieldButton" text="✎" onAction="#onEditDescriptionField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>
                                                        <HBox fx:id="addressRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyAddressLabel" text="Address" wrapText="true" styleClass="agency-info-text"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editAddressFieldButton" text="✎" onAction="#onEditAddressField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>
                                                        <HBox fx:id="websiteRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyWebsiteLabel" text="Website" wrapText="true" styleClass="agency-info-text"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editWebsiteFieldButton" text="✎" onAction="#onEditWebsiteField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>
                                                        <HBox fx:id="phoneRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyPhoneLabel" text="Phone" wrapText="true" styleClass="agency-info-text"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editPhoneFieldButton" text="✎" onAction="#onEditPhoneField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>
                                                        <HBox fx:id="countryRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                            <children>
                                                                <Label fx:id="agencyCountryLabel" text="Country" wrapText="true" styleClass="agency-info-text"/>
                                                                <Region HBox.hgrow="ALWAYS"/>
                                                                <Button fx:id="editCountryFieldButton" text="✎" onAction="#onEditCountryField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                            </children>
                                                        </HBox>

                                                        <VBox fx:id="editPanel" spacing="8.0" visible="false" managed="false" styleClass="agency-edit-panel">
                                                            <children>
                                                                <TextField fx:id="editAgencyNameField" promptText="Agency name"/>
                                                                <TextArea fx:id="editDescriptionField" promptText="Description" prefRowCount="4"/>
                                                                <TextField fx:id="editAddressField" promptText="Address"/>
                                                                <TextField fx:id="editWebsiteField" promptText="Website URL"/>
                                                                <TextField fx:id="editPhoneField" promptText="Phone"/>
                                                                <TextField fx:id="editCountryField" promptText="Country (ISO2)"/>
                                                            </children>
                                                        </VBox>

                                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                            <children>
                                                                <Button fx:id="editButton" text="Edit info" onAction="#onEditAgency" visible="false" managed="false" styleClass="agency-overlay-action agency-panel-hover-action"/>
                                                                <Button fx:id="saveButton" text="Save" onAction="#onSaveAgency" visible="false" managed="false" styleClass="agency-overlay-action"/>
                                                                <Button fx:id="cancelEditButton" text="Cancel" onAction="#onCancelEdit" visible="false" managed="false" styleClass="agency-overlay-action"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox spacing="8.0" styleClass="agency-tabs-row">
                                                    <children>
                                                        <JFXButton fx:id="postsTabButton" text="Posts" onAction="#showPostsTab" styleClass="agency-tab-pill agency-tab-pill-active"/>
                                                        <JFXButton fx:id="aboutTabButton" text="About" onAction="#showAboutTab" styleClass="agency-tab-pill"/>
                                                        <JFXButton fx:id="offersTabButton" text="Offers" onAction="#showOffersTab" styleClass="agency-tab-pill"/>
                                                    </children>
                                                </HBox>
                                                <VBox fx:id="mainContentPlaceholder" VBox.vgrow="ALWAYS" spacing="10.0" styleClass="agency-main-content-panel">
                                                    <padding><Insets top="20.0" right="22.0" bottom="20.0" left="22.0"/></padding>
                                                    <children>
                                                        <Label fx:id="placeholderTitleLabel" text="Posts" styleClass="agency-main-title"/>
                                                        <Label fx:id="placeholderSubtitleLabel" wrapText="true"
                                                               text="Content area ready for future feed, offers, and timeline modules."
                                                               styleClass="agency-main-subtitle"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label fx:id="feedbackLabel" text="" styleClass="offers-subtitle"/>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
