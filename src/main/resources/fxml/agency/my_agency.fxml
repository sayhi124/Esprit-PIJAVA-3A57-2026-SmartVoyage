<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.gestionagences.MyAgencyController"
            styleClass="immersive-root">
    <left>
        <VBox prefWidth="278.0" minWidth="260.0" spacing="10.0" styleClass="sidebar-immersive">
            <padding><Insets top="22.0" right="16.0" bottom="18.0" left="16.0"/></padding>
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="✦ SmartVoyage" styleClass="sidebar-logo"/>
                        <Label text="My agency" styleClass="sidebar-subtitle"/>
                    </children>
                </VBox>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⌂  Home" onAction="#onHome" styleClass="sidebar-nav-item"/>
                <Button text="🧳  Offers" onAction="#onOffres" styleClass="sidebar-nav-item"/>
                <Button text="📍  Agencies" onAction="#onAgences">
                    <styleClass>
                        <String fx:value="sidebar-nav-item"/>
                        <String fx:value="sidebar-nav-item-active"/>
                    </styleClass>
                </Button>
                <Button text="✉  Messages" onAction="#onMessagerie" styleClass="sidebar-nav-item"/>
                <Button text="⭐  Recommendations" onAction="#onRecommandation" styleClass="sidebar-nav-item"/>
                <Button text="📅  Events" onAction="#onEvenement" styleClass="sidebar-nav-item"/>
                <Button text="📊  Dashboard IA" onAction="#onDashboardIa" styleClass="sidebar-nav-item"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="👑  Premium" onAction="#onPremium" styleClass="premium-nav-button"/>
                <Button text="🔔  Notifications" onAction="#onNotifications" styleClass="sidebar-nav-item"/>
                <Button text="👤  My Profile" onAction="#onProfile" styleClass="sidebar-nav-item"/>
                <Separator styleClass="sidebar-rule"/>
                <Button text="⎋  Deconnexion" onAction="#onLogout" styleClass="sidebar-nav-item"/>
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="sidebar-footer-block">
                    <children>
                        <Button text="🌙" onAction="#onThemeToggle" styleClass="theme-immersive-button"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <StackPane styleClass="offers-immersive-stack">
            <children>
                <Region styleClass="offers-page-overlay"/>
                <Region styleClass="offers-cards-spotlight"/>
                <ScrollPane fitToWidth="true" fitToHeight="false" styleClass="agency-page-scroll">
                    <content>
                        <VBox spacing="16.0" styleClass="agency-page-root">
                            <padding><Insets top="20.0" right="24.0" bottom="20.0" left="24.0"/></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="agency-header-row">
                                    <children>
                                        <Label text="Agency Profile" styleClass="offers-mini-logo"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Button text="Back to agencies" onAction="#onBackToAgencies" styleClass="offers-top-login-button"/>
                                    </children>
                                </HBox>

                                <StackPane fx:id="bannerStack" prefHeight="280.0" minHeight="250.0" maxHeight="340.0">
                                    <children>
                                        <Region styleClass="agency-cover-banner"/>
                                        <ImageView fx:id="coverImageView" preserveRatio="false" pickOnBounds="true" smooth="true" cache="true"
                                                   styleClass="agency-cover-image"/>
                                        <Region styleClass="agency-cover-gradient"/>
                                        <Button fx:id="editCoverButton" text="Edit cover" onAction="#onEditCover"
                                                visible="false" managed="false" styleClass="agency-overlay-action agency-cover-hover-action"
                                                StackPane.alignment="TOP_RIGHT">
                                            <StackPane.margin><Insets top="14.0" right="14.0"/></StackPane.margin>
                                        </Button>
                                    </children>
                                </StackPane>

                                <HBox spacing="18.0" styleClass="agency-lower-section">
                                    <children>
                                        <VBox prefWidth="420.0" minWidth="400.0" maxWidth="440.0" spacing="12.0">
                                            <children>
                                                <StackPane prefHeight="106.0">
                                                    <children>
                                                        <StackPane prefWidth="168.0" prefHeight="168.0" minWidth="168.0" minHeight="168.0" maxWidth="168.0" maxHeight="168.0" styleClass="agency-avatar-shell" StackPane.alignment="TOP_CENTER">
                                                            <StackPane.margin><Insets top="-68.0"/></StackPane.margin>
                                                            <children>
                                                                <ImageView fx:id="avatarImageView" fitWidth="156.0" fitHeight="156.0" preserveRatio="false"
                                                                           pickOnBounds="true" smooth="true" cache="true" styleClass="agency-avatar-image"/>
                                                                <Label fx:id="avatarFallbackLabel" text="A" styleClass="agency-avatar-icon"/>
                                                                <Button fx:id="editAvatarButton" text="Edit" onAction="#onEditAvatar"
                                                                        visible="false" managed="false" styleClass="agency-avatar-edit agency-avatar-hover-action"
                                                                        StackPane.alignment="BOTTOM_RIGHT">
                                                                    <StackPane.margin><Insets right="3.0" bottom="3.0"/></StackPane.margin>
                                                                </Button>
                                                            </children>
                                                        </StackPane>
                                                    </children>
                                                </StackPane>

                                                <VBox prefWidth="420.0" spacing="12.0">
                                                    <children>
                                                        <VBox spacing="10.0" styleClass="agency-info-card">
                                                            <padding><Insets top="16.0" right="14.0" bottom="16.0" left="14.0"/></padding>
                                                            <children>
                                                                <HBox alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label fx:id="agencyTitleLabel" text="My Agency" wrapText="true" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" styleClass="agency-name-title"/>
                                                                        <Label fx:id="agencyVerifiedBadgeLabel" text="Verified" visible="false" managed="false" styleClass="agency-verified-badge"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editNameFieldButton" text="Edit" onAction="#onEditNameField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>

                                                                <HBox fx:id="descriptionRow" alignment="TOP_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label text="📝" styleClass="agency-field-icon"/>
                                                                        <Label fx:id="agencyDescriptionLabel" text="Description" wrapText="true" styleClass="agency-info-text"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editDescriptionFieldButton" text="Edit" onAction="#onEditDescriptionField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>

                                                        <VBox spacing="10.0" styleClass="agency-info-card">
                                                            <padding><Insets top="16.0" right="14.0" bottom="16.0" left="14.0"/></padding>
                                                            <children>
                                                                <HBox fx:id="addressRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label text="📍" styleClass="agency-field-icon"/>
                                                                        <Label fx:id="agencyAddressLabel" text="Address" wrapText="true" styleClass="agency-info-text"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editAddressFieldButton" text="Edit" onAction="#onEditAddressField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>
                                                                <HBox fx:id="websiteRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label text="🌐" styleClass="agency-field-icon"/>
                                                                        <Label fx:id="agencyWebsiteLabel" text="Website" wrapText="true" styleClass="agency-info-text"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editWebsiteFieldButton" text="Edit" onAction="#onEditWebsiteField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>
                                                                <HBox fx:id="phoneRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label text="📞" styleClass="agency-field-icon"/>
                                                                        <Label fx:id="agencyPhoneLabel" text="Phone" wrapText="true" styleClass="agency-info-text"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editPhoneFieldButton" text="Edit" onAction="#onEditPhoneField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>
                                                                <HBox fx:id="countryRow" alignment="CENTER_LEFT" spacing="8.0" styleClass="agency-info-row">
                                                                    <children>
                                                                        <Label text="🗺" styleClass="agency-field-icon"/>
                                                                        <Label fx:id="agencyCountryLabel" text="Country" wrapText="true" styleClass="agency-info-text"/>
                                                                        <Region HBox.hgrow="ALWAYS"/>
                                                                        <Button fx:id="editCountryFieldButton" text="Edit" onAction="#onEditCountryField" visible="false" managed="false" styleClass="agency-edit-icon"/>
                                                                    </children>
                                                                </HBox>
                                                            </children>
                                                        </VBox>

                                                        <VBox fx:id="editPanel" spacing="10.0" visible="false" managed="false" styleClass="agency-edit-panel">
                                                            <children>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextField fx:id="editAgencyNameField" promptText="Agency name"/>
                                                                        <Label fx:id="editAgencyNameErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextArea fx:id="editDescriptionField" promptText="Description" prefRowCount="4"/>
                                                                        <Label fx:id="editDescriptionErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextField fx:id="editAddressField" promptText="Address"/>
                                                                        <Label fx:id="editAddressErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextField fx:id="editWebsiteField" promptText="Website URL"/>
                                                                        <Label fx:id="editWebsiteErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextField fx:id="editPhoneField" promptText="Phone"/>
                                                                        <Label fx:id="editPhoneErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                                <VBox spacing="2.0">
                                                                    <children>
                                                                        <TextField fx:id="editCountryField" promptText="Country (ISO2)"/>
                                                                        <Label fx:id="editCountryErrorLabel" styleClass="agency-edit-field-error" wrapText="true" maxWidth="1.7976931348623157E308" visible="false" managed="false"/>
                                                                    </children>
                                                                </VBox>
                                                            </children>
                                                        </VBox>

                                                        <HBox spacing="8.0" alignment="CENTER_LEFT">
                                                            <children>
                                                                <Button fx:id="editButton" text="Edit info" onAction="#onEditAgency" visible="false" managed="false" styleClass="agency-overlay-action agency-panel-hover-action"/>
                                                                <Button fx:id="saveButton" text="Save" onAction="#onSaveAgency" visible="false" managed="false" styleClass="agency-overlay-action"/>
                                                                <Button fx:id="cancelEditButton" text="Cancel" onAction="#onCancelEdit" visible="false" managed="false" styleClass="agency-overlay-action"/>
                                                            </children>
                                                        </HBox>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>

                                        <VBox spacing="12.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <HBox spacing="10.0" alignment="CENTER_LEFT" styleClass="agency-tabs-row">
                                                    <children>
                                                        <Button fx:id="postsTabButton" text="Posts" onAction="#showPostsTab" styleClass="agency-tab-pill agency-tab-pill-active"/>
                                                        <Button fx:id="aboutTabButton" text="About" onAction="#showAboutTab" styleClass="agency-tab-pill"/>
                                                        <Button fx:id="offersTabButton" text="Offers" onAction="#showOffersTab" styleClass="agency-tab-pill"/>
                                                        <Region HBox.hgrow="ALWAYS"/>
                                                        <Button fx:id="addPostButton" text="+ Add post" onAction="#onAddPost" visible="false" managed="false" styleClass="agency-overlay-action"/>
                                                    </children>
                                                </HBox>

                                                <VBox fx:id="mainContentPlaceholder" spacing="10.0" styleClass="agency-main-content-panel">
                                                    <padding><Insets top="20.0" right="22.0" bottom="20.0" left="22.0"/></padding>
                                                    <children>
                                                        <Label fx:id="placeholderTitleLabel" text="Posts" styleClass="agency-main-title"/>
                                                        <Label fx:id="placeholderSubtitleLabel" wrapText="true"
                                                               text="Main feed area is ready for posts and interactions."
                                                               styleClass="agency-main-subtitle"/>
                                                        <ScrollPane fx:id="postsScrollPane" fitToWidth="true" visible="false" managed="false" styleClass="agency-posts-scroll">
                                                            <content>
                                                                <VBox fx:id="postsListBox" spacing="12.0"/>
                                                            </content>
                                                        </ScrollPane>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Label fx:id="feedbackLabel" text="" styleClass="offers-subtitle"/>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </children>
        </StackPane>
    </center>
</BorderPane>
