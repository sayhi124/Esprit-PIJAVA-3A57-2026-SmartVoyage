<?xml version="1.0" encoding="UTF-8"?>

<!-- Liste des agences (integration agency/list). -->
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="controllers.gestionagences.AgenciesListController"
           prefHeight="720.0"
           prefWidth="1200.0"
           styleClass="cosmic-root agency-app-root">
   <children>
      <Region maxHeight="Infinity" maxWidth="Infinity" mouseTransparent="true" styleClass="welcome-starfield" />
      <VBox maxHeight="Infinity" maxWidth="Infinity" spacing="0.0">
         <children>
            <fx:include fx:id="loggedHeader" source="../components/app_logged_header.fxml" />
            <ScrollPane fitToWidth="true" styleClass="agency-scroll" VBox.vgrow="ALWAYS">
               <content>
                  <VBox spacing="20.0" styleClass="agency-list-inner">
                     <padding>
                        <Insets bottom="48.0" left="40.0" right="40.0" top="8.0" />
                     </padding>
                     <children>
                        <VBox spacing="8.0">
                           <children>
                              <Label styleClass="agency-hero-kicker" text="NOS AGENCES" />
                              <Label styleClass="agency-hero-title" text="DÉCOUVREZ NOS AGENCES" />
                              <Label styleClass="agency-hero-sub" text="Explorez notre réseau d'agences de voyage certifiées" />
                           </children>
                        </VBox>
                        <HBox alignment="CENTER_LEFT" spacing="12.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#onMapStub" styleClass="hero-btn-primary" text="Voir sur la carte" />
                              <Button mnemonicParsing="false" onAction="#onMyAgency" styleClass="hero-btn-secondary" text="Mon agence" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="agency-toolbar">
                           <children>
                              <TextField fx:id="searchField"
                                         prefWidth="360.0"
                                         promptText="Rechercher par nom ou description…"
                                         styleClass="agency-search-field" />
                              <ComboBox fx:id="countryFilter" prefWidth="200.0" styleClass="agency-country-combo" />
                           </children>
                        </HBox>
                        <Label fx:id="countLabel" styleClass="agency-results-count" text="0 agences trouvées" />
                        <FlowPane fx:id="cardsPane"
                                  hgap="24.0"
                                  prefWrapLength="980.0"
                                  styleClass="agency-cards-flow"
                                  vgap="24.0" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </children>
</StackPane>
