<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.gestionoffres.AgencyReservationsController"
      spacing="12" prefWidth="760" maxWidth="760" styleClass="event-form-root">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <VBox spacing="12" styleClass="event-form-shell">
        <padding>
            <Insets top="14" right="14" bottom="14" left="14"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
                <Label text="Reservation Requests" styleClass="events-form-title"/>
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
                <ComboBox fx:id="offerFilterCombo" promptText="Filter by offer" prefWidth="260" styleClass="event-form-input"/>
                <ComboBox fx:id="statusFilterCombo" promptText="Filter by status" prefWidth="200" styleClass="event-form-input"/>
                <Button text="Refresh" onAction="#onRefresh" styleClass="event-form-ok-btn"/>
            </children>
        </HBox>

        <Label fx:id="reservationsBannerLabel" managed="false" visible="false" wrapText="true" styleClass="events-inline-status"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="events-scroll" VBox.vgrow="ALWAYS">
            <content>
                <VBox fx:id="reservationsCardsContainer" spacing="10"/>
            </content>
        </ScrollPane>
    </VBox>
</VBox>
