<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.controlsfx.control.CheckComboBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.gestionoffres.OfferFormController"
      spacing="12"
      prefWidth="760"
      maxWidth="760"
      styleClass="event-form-root">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <VBox spacing="12" styleClass="event-form-shell">
        <padding>
            <Insets top="14" right="14" bottom="14" left="14"/>
        </padding>

        <VBox spacing="8" styleClass="event-form-section">
            <children>
                <Label text="Offer Details" styleClass="event-form-section-title"/>

                <VBox spacing="4" styleClass="event-field-group">
                    <children>
                        <Label text="Title" styleClass="event-form-label"/>
                        <TextField fx:id="titleField" promptText="Offer title" styleClass="event-form-input"/>
                    </children>
                </VBox>

                <VBox spacing="4" styleClass="event-field-group">
                    <children>
                        <Label text="Countries" styleClass="event-form-label"/>
                        <TextField fx:id="countrySearchField" promptText="Search country..." styleClass="event-form-input"/>
                        <CheckComboBox fx:id="countriesCombo" prefHeight="40.0" styleClass="offer-countries-checkcombo"/>
                    </children>
                </VBox>

                <VBox spacing="4" styleClass="event-field-group">
                    <children>
                        <Label text="Description" styleClass="event-form-label"/>
                        <TextArea fx:id="descriptionArea" wrapText="true" prefRowCount="4" promptText="Describe this offer..."
                                  styleClass="event-form-input event-form-area"/>
                    </children>
                </VBox>
            </children>
        </VBox>

        <VBox spacing="8" styleClass="event-form-section">
            <children>
                <Label text="Dates and Pricing" styleClass="event-form-section-title"/>

                <HBox spacing="10" styleClass="event-date-time-row">
                    <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="event-field-group">
                            <children>
                                <Label text="Departure Date" styleClass="event-form-label"/>
                                <DatePicker fx:id="departureDatePicker" maxWidth="1.7976931348623157E308" styleClass="event-form-date"/>
                            </children>
                        </VBox>

                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="event-field-group">
                            <children>
                                <Label text="Return Date" styleClass="event-form-label"/>
                                <DatePicker fx:id="returnDatePicker" maxWidth="1.7976931348623157E308" styleClass="event-form-date"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <HBox spacing="10" styleClass="event-date-time-row">
                    <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="event-field-group">
                            <children>
                                <Label text="Price" styleClass="event-form-label"/>
                                <TextField fx:id="priceField" promptText="0.00" styleClass="event-form-input"/>
                            </children>
                        </VBox>

                        <VBox spacing="4" HBox.hgrow="ALWAYS" styleClass="event-field-group">
                            <children>
                                <Label text="Currency" styleClass="event-form-label"/>
                                <ComboBox fx:id="currencyCombo" promptText="Select currency" maxWidth="1.7976931348623157E308" styleClass="event-form-input"/>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="4" styleClass="event-field-group">
                    <children>
                        <Label text="Available Seats" styleClass="event-form-label"/>
                        <TextField fx:id="availableSeatsField" promptText="e.g. 25" styleClass="event-form-input"/>
                    </children>
                </VBox>

                <VBox spacing="4" styleClass="event-field-group">
                    <children>
                        <Label text="Image (optional)" styleClass="event-form-label"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <children>
                                <TextField fx:id="imageField" editable="false" promptText="uploads/filename.png" styleClass="event-form-input" HBox.hgrow="ALWAYS"/>
                                <Button text="Upload" onAction="#onUploadImage" styleClass="event-form-cancel-btn"/>
                            </children>
                        </HBox>
                        <ImageView fx:id="imagePreview" fitWidth="250.0" fitHeight="140.0" preserveRatio="true" smooth="true" styleClass="offer-image-preview"/>
                    </children>
                </VBox>

                <HBox spacing="10" alignment="CENTER_RIGHT" styleClass="events-form-actions-row">
                    <children>
                        <Button text="Cancel" onAction="#onCancelClick" styleClass="event-form-cancel-btn"/>
                        <Button fx:id="submitButton" text="Create" onAction="#onSaveClick" styleClass="event-form-ok-btn"/>
                    </children>
                </HBox>
            </children>
        </VBox>
    </VBox>
</VBox>
