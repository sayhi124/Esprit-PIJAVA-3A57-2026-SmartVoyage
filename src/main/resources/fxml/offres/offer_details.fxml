<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controllers.gestionoffres.OfferDetailsController"
      spacing="12" prefWidth="760" maxWidth="760" styleClass="event-form-root">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <VBox spacing="12" styleClass="offer-details-shell">
        <padding>
            <Insets top="14" right="14" bottom="14" left="14"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <children>
                <Button text="Back" onAction="#onBackClick" styleClass="event-form-cancel-btn"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="statusBadgeLabel" text="PENDING" styleClass="reservation-status-badge reservation-status-pending" managed="false" visible="false"/>
            </children>
        </HBox>

        <StackPane styleClass="offer-details-cover-wrap">
            <children>
                <ImageView fx:id="coverImageView" fitWidth="740" fitHeight="250" preserveRatio="false" smooth="true" styleClass="offer-details-cover-image"/>
            </children>
        </StackPane>

        <Label fx:id="titleLabel" text="Offer title" styleClass="offer-details-title"/>
        <Label fx:id="countriesLabel" text="Countries" styleClass="offer-details-countries" wrapText="true"/>

        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="offer-details-meta-row">
            <children>
                <Label fx:id="priceLabel" text="0 EUR" styleClass="offer-details-meta"/>
                <Label fx:id="datesLabel" text="2026-01-01 -> 2026-01-10" styleClass="offer-details-meta"/>
                <Label fx:id="seatsLabel" text="0" styleClass="offer-details-meta"/>
            </children>
        </HBox>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="events-scroll" VBox.vgrow="ALWAYS">
            <content>
                <Label fx:id="descriptionLabel" text="Description" wrapText="true" styleClass="offer-details-description"/>
            </content>
        </ScrollPane>

        <Label fx:id="reservationHintLabel" text="En attente de validation par l'agence" styleClass="event-card-meta" managed="false" visible="false"/>

        <Button fx:id="reserveButton" text="Reserve" onAction="#onReserveClick" styleClass="offer-details-reserve-btn" managed="false" visible="false"/>
    </VBox>
</VBox>
